# Bắt buộc để gọi OpenAI image gen. Copy file này thành `.env.local` và điền key.
OPENAI_API_KEY=your_openai_api_key_here

# Tùy chọn: model & chất lượng ảnh (mặc định trong code nếu bỏ trống)
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_QUALITY=medium      # low | medium | high
# OPENAI_IMAGE_SIZE=1536x1024      # 1024x1024 | 1536x1024 | 1024x1536 | auto

# Nếu KHÔNG có OPENAI_API_KEY, API chạy chế độ MOCK (trả lại ảnh phòng gốc) để test UI.
